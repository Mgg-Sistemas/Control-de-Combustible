# Variables de entorno de Supabase (cliente Expo).
# 1. Copia este archivo a .env
# 2. Reemplaza los valores con los de tu proyecto: Supabase Studio > Project Settings > API
# 3. Reinicia el servidor:  npx expo start -c
#
# Nota: el prefijo EXPO_PUBLIC_ es obligatorio para que Expo exponga la variable al cliente.

EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
